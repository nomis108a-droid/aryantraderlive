rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to ensure "fast reads" for the leaderboard and hub content
    // In a prototype with mock auth, we allow permissive writes for testing
    match /{collectionName}/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Explicit rules for critical paths
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    match /registrations/{regId} {
      allow read: if true;
      allow write: if true;
    }

    match /weeklywar/{warId} {
      allow read: if true;
      allow write: if true;
    }

    match /submissions/{subId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /proofMedia/{proofId} {
      allow read: if true;
      allow write: if true;
    }
  }
}